---
// Direction A — Kinetic Editorial
import Switcher from '../components/Switcher.astro';
import { META, EVENT_DATE_ISO, agenda, faqs, audiences, packageBenefits } from '../content';

const whyCards = [
  { num: '①', title: 'Lessons, not lectures', body: "No theory, no TED-talk polish. Real people who navigated the exact journey you're on — sharing what worked, what didn't, and what they'd do differently." },
  { num: '②', title: 'Your network, rebuilt', body: 'The room is the product. Founders, operators, advisors, and investors who look like you and have been where you are. Leave with relationships, not just business cards.' },
  { num: '③', title: 'The playbook, decoded', body: 'The UK job market, workplace culture, and the unwritten systems that create opportunity — explained by people who cracked them.' },
  { num: '④', title: 'A community that continues', body: "Finding X isn't a one-day event. It's your entry into BuildersCabal's growing UK community — the conversations keep going long after the chairs are stacked." },
];

const speakerSlots = ['Fireside guest', 'Panelist', 'Panelist', 'Panelist'];

const packages = [
  { tier: 'COMMUNITY PARTNER', price: '£500', tag: 'Be part of the conversation.', border: 'rgba(250,246,239,.2)', bg: 'transparent', accent: 'rgba(250,246,239,.6)', benefits: packageBenefits.community },
  { tier: 'SUPPORTING PARTNER', price: '£1,500', tag: 'Engage the room directly.', border: '#E4572E', bg: 'rgba(228,87,46,.1)', accent: '#E4572E', benefits: packageBenefits.supporting },
  { tier: 'HEADLINE PARTNER', price: '£3,000', tag: 'Shape Finding X itself.', border: 'rgba(250,246,239,.2)', bg: 'transparent', accent: 'rgba(250,246,239,.6)', benefits: packageBenefits.headline },
];

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#speakers', label: 'Speakers' },
  { href: '#agenda', label: 'Agenda' },
  { href: '#partner', label: 'Partner' },
  { href: '#faq', label: 'FAQ' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{META.title}</title>
<meta name="description" content={META.description}>
<meta property="og:title" content={META.title}>
<meta property="og:description" content={META.description}>
<meta property="og:type" content="website">
<link rel="icon" type="image/png" href="/assets/bc-logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<style is:global>
html{scroll-behavior:smooth}
body{margin:0;background:#FAF6EF;color:#1C1613;font-family:'Space Grotesk',sans-serif;-webkit-font-smoothing:antialiased}
@keyframes fx-marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes fx-pulse{0%,100%{opacity:1}50%{opacity:.35}}
@media (prefers-reduced-motion: reduce){*{animation-duration:.01ms !important;transition-duration:.01ms !important}}
#fxnav-links{display:flex;align-items:center;gap:clamp(12px,2.5vw,28px)}
#fxnav-burger{display:none}
.a-nav-cta{white-space:nowrap}
.a-brand{white-space:nowrap}
@media (max-width:840px){#fxnav-links{display:none}#fxnav-burger{display:inline-block}.a-nav-cta{font-size:12px !important;padding:9px 16px !important}}
@media (max-width:600px){.a-byline{display:none}}
@media (max-width:380px){.a-nav-cta{font-size:11px !important;padding:8px 12px !important}.a-brand{font-size:15px !important}}
@media (max-width:600px){
#fx-h1{font-size:clamp(40px,14vw,53px) !important}
#fx-cdrow{width:100%}
#fx-cdrow>div{flex:1;min-width:0 !important;padding:12px 6px !important}
#fx-cdrow [data-cd]{font-size:22px !important}
}
#fx-menu{display:none}
#fx-menu.open{display:flex}
.a-nl{transition:opacity .15s}
.a-nl:hover{opacity:1 !important}
.a-cta{transition:background .15s}
.a-cta:hover{background:#C2452A !important}
.a-ghost{transition:background .15s,color .15s}
.a-ghost:hover{background:#1C1613 !important;color:#FAF6EF !important}
.a-card{transition:border-color .15s}
.a-card:hover{border-color:#E4572E !important}
.a-chip{transition:background .15s,border-color .15s,color .15s}
.a-chip:hover{background:#E4572E;border-color:#E4572E !important;color:#FAF6EF}
.a-news:hover{background:#000 !important}
.a-fl{transition:opacity .15s}
.a-fl:hover{opacity:1 !important}
[data-faq-a][hidden]{display:none}
</style>
</head>
<body>
<Switcher active="a" />

<!-- NAV -->
<nav style="position:sticky;top:0;z-index:50;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:14px clamp(20px,5vw,64px);background:rgba(250,246,239,.88);backdrop-filter:blur(12px);border-bottom:1px solid rgba(28,22,19,.1)">
  <a href="#top" style="display:flex;align-items:center;gap:10px;text-decoration:none;color:#1C1613">
    <img src="/assets/bc-logo.png" alt="BuildersCabal" style="height:22px;width:auto">
    <span class="a-brand" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:17px;letter-spacing:-0.02em">FINDING X</span>
    <span class="a-byline" style="font-size:11px;opacity:.55;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap">by BuildersCabal</span>
  </a>
  <div style="display:flex;align-items:center;gap:clamp(12px,2.5vw,28px)">
    <div id="fxnav-links">
      {navLinks.map((l) => (
        <a href={l.href} class="a-nl" style="color:#1C1613;text-decoration:none;font-size:14px;opacity:.75">{l.label}</a>
      ))}
    </div>
    <a href="#register" class="a-cta a-nav-cta" style="background:#E4572E;color:#FAF6EF;text-decoration:none;font-weight:600;font-size:14px;padding:10px 22px;border-radius:999px">Register Free</a>
    <button id="fxnav-burger" aria-label="Menu" style="background:none;border:1.5px solid #1C1613;border-radius:10px;cursor:pointer;padding:8px 11px;font-size:16px;line-height:1;color:#1C1613;min-height:38px">☰</button>
  </div>
  <div id="fx-menu" style="position:absolute;top:100%;left:0;right:0;background:#FAF6EF;border-bottom:1.5px solid rgba(28,22,19,.15);flex-direction:column;padding:8px 24px 16px">
    {navLinks.map((l, i) => (
      <a href={l.href} data-menu-link style={`color:#1C1613;text-decoration:none;font-size:17px;font-weight:500;padding:14px 2px;${i < navLinks.length - 1 ? 'border-bottom:1px solid rgba(28,22,19,.08)' : ''}`}>{l.label}</a>
    ))}
  </div>
</nav>

<!-- HERO -->
<header id="top" style="padding:clamp(48px,9vh,110px) clamp(20px,5vw,64px) 56px;min-height:78vh;display:flex;flex-direction:column;justify-content:center">
  <div style="font-family:'Space Grotesk',monospace;font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:#E4572E;font-weight:600;margin-bottom:22px">A BuildersCabal Initiative · Leeds · 26 Sept 2026</div>
  <h1 id="fx-h1" style="margin:0;font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(56px,10.5vw,168px);line-height:.92;letter-spacing:-0.035em">
    <span style="display:block">FINDING</span>
    <span id="fx-rotword" style="display:block;color:#E4572E">OPPORTUNITY</span>
  </h1>
  <p style="max-width:620px;font-size:clamp(16px,1.6vw,20px);line-height:1.55;opacity:.8;margin:32px 0 0">You moved for something. Let's find it. Honest lessons from Africans who've built thriving careers and businesses in the UK — for those still finding their footing.</p>
  <div style="display:flex;flex-wrap:wrap;align-items:center;gap:28px;margin-top:36px">
    <div id="fx-cdrow" style="display:flex;gap:10px">
      <div style="text-align:center;background:#1C1613;color:#FAF6EF;border-radius:12px;padding:12px 14px;min-width:64px"><div data-cd="dd" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:26px">00</div><div style="font-size:10px;letter-spacing:.14em;opacity:.6">DAYS</div></div>
      <div style="text-align:center;background:#1C1613;color:#FAF6EF;border-radius:12px;padding:12px 14px;min-width:64px"><div data-cd="hh" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:26px">00</div><div style="font-size:10px;letter-spacing:.14em;opacity:.6">HRS</div></div>
      <div style="text-align:center;background:#1C1613;color:#FAF6EF;border-radius:12px;padding:12px 14px;min-width:64px"><div data-cd="mm" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:26px">00</div><div style="font-size:10px;letter-spacing:.14em;opacity:.6">MIN</div></div>
      <div style="text-align:center;background:#1C1613;color:#FAF6EF;border-radius:12px;padding:12px 14px;min-width:64px"><div data-cd="ss" style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:26px;animation:fx-pulse 2s infinite">00</div><div style="font-size:10px;letter-spacing:.14em;opacity:.6">SEC</div></div>
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap">
      <a id="register" href="#newsletter" class="a-cta" style="background:#E4572E;color:#FAF6EF;text-decoration:none;font-weight:600;font-size:16px;padding:16px 34px;border-radius:999px">Register Free</a>
      <a href="#partner" class="a-ghost" style="border:1.5px solid #1C1613;color:#1C1613;text-decoration:none;font-weight:600;font-size:16px;padding:16px 34px;border-radius:999px">Partner With Us</a>
    </div>
  </div>
</header>

<!-- MARQUEE -->
<div style="overflow:hidden;background:#1C1613;color:#FAF6EF;padding:14px 0;white-space:nowrap">
  <div style="display:inline-flex;gap:0;animation:fx-marquee 24s linear infinite">
    <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:16px;letter-spacing:.12em">LIVING · WORKING · BUILDING IN THE UK&nbsp;&nbsp;✦&nbsp;&nbsp;LEEDS · 26 SEPT 2026&nbsp;&nbsp;✦&nbsp;&nbsp;FINDING X · BY BUILDERSCABAL&nbsp;&nbsp;✦&nbsp;&nbsp;</span>
    <span style="font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:16px;letter-spacing:.12em">LIVING · WORKING · BUILDING IN THE UK&nbsp;&nbsp;✦&nbsp;&nbsp;LEEDS · 26 SEPT 2026&nbsp;&nbsp;✦&nbsp;&nbsp;FINDING X · BY BUILDERSCABAL&nbsp;&nbsp;✦&nbsp;&nbsp;</span>
  </div>
</div>

<!-- X STATEMENT -->
<section data-reveal style="padding:clamp(80px,12vh,140px) clamp(20px,5vw,64px);max-width:980px;margin:0 auto;text-align:center">
  <p style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(24px,3.4vw,42px);line-height:1.3;letter-spacing:-0.01em;margin:0">Every year, thousands of us arrive in the UK with degrees, experience, and ambition — searching for something we can't always name.</p>
  <p style="font-family:'Bricolage Grotesque',sans-serif;font-weight:500;font-size:clamp(24px,3.4vw,42px);line-height:1.3;margin:28px 0 0;opacity:.55">Opportunity. Community. Direction. Home.</p>
  <p style="font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(28px,4vw,52px);line-height:1.2;margin:36px 0 0;color:#E4572E">We call it X. This event is about finding it — faster.</p>
</section>

<!-- ABOUT -->
<section id="about" data-reveal style="padding:clamp(64px,10vh,120px) clamp(20px,5vw,64px);background:#1C1613;color:#FAF6EF">
  <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(32px,5vw,80px)">
    <div>
      <div style="font-size:12px;letter-spacing:.22em;color:#E4572E;font-weight:600;margin-bottom:18px">01 — WHY FINDING X</div>
      <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(32px,4vw,54px);line-height:1.05;letter-spacing:-0.02em;margin:0">Hard work was never the whole equation.</h2>
    </div>
    <div style="font-size:17px;line-height:1.7;opacity:.85;display:flex;flex-direction:column;gap:18px">
      <p style="margin:0">You did everything right. Strong career back home. Big plans for the new one. Then you landed — and the network you spent a decade building disappeared overnight. The CV that opened doors now gets silence. The rules changed, and nobody handed you the new playbook.</p>
      <p style="margin:0">Succeeding in the UK isn't about working harder. It's about the <strong style="color:#E4572E">right mindset</strong>, the <strong style="color:#E4572E">right information</strong>, and the <strong style="color:#E4572E">right people</strong> — and most of us only find those years in, after learning the expensive way.</p>
      <p style="margin:0;font-weight:600;color:#FAF6EF">Finding X exists to close that gap. One room. No motivational fluff — just practical frameworks, honest stories, and lessons that would otherwise cost you years.</p>
    </div>
  </div>
</section>

<!-- WHY ATTEND -->
<section data-reveal style="padding:clamp(64px,10vh,120px) clamp(20px,5vw,64px);max-width:1200px;margin:0 auto">
  <div style="font-size:12px;letter-spacing:.22em;color:#E4572E;font-weight:600;margin-bottom:14px">02 — WHY ATTEND</div>
  <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(30px,3.8vw,50px);letter-spacing:-0.02em;margin:0 0 40px">Lessons, not lectures.</h2>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:18px">
    {whyCards.map((card) => (
      <div class="a-card" style="border:1.5px solid rgba(28,22,19,.15);border-radius:18px;padding:28px;display:flex;flex-direction:column;gap:14px;background:#FFFDF8">
        <div style="font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:30px;color:#E4572E">{card.num}</div>
        <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:21px;margin:0">{card.title}</h3>
        <p style="font-size:15px;line-height:1.6;opacity:.75;margin:0">{card.body}</p>
      </div>
    ))}
  </div>
</section>

<!-- SPEAKERS -->
<section id="speakers" data-reveal style="padding:clamp(64px,10vh,120px) clamp(20px,5vw,64px);max-width:1200px;margin:0 auto">
  <div style="font-size:12px;letter-spacing:.22em;color:#E4572E;font-weight:600;margin-bottom:14px">03 — SPEAKERS</div>
  <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(30px,3.8vw,50px);letter-spacing:-0.02em;margin:0 0 16px">Voices worth crossing the city for.</h2>
  <p style="max-width:560px;font-size:16px;line-height:1.6;opacity:.75;margin:0 0 40px">We're curating a lineup of Africans who've built remarkable careers and companies in the UK. Announcements drop soon — register now and be first to know.</p>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px">
    {speakerSlots.map((s) => (
      <div style="border-radius:18px;overflow:hidden;background:#1C1613;aspect-ratio:4/5;position:relative;display:flex;align-items:flex-end">
        <div style="position:absolute;inset:0;background:radial-gradient(circle at 50% 32%, rgba(228,87,46,.55), transparent 62%)"></div>
        <div style="position:absolute;top:34%;left:50%;transform:translate(-50%,-50%);font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:64px;color:rgba(250,246,239,.25)">?</div>
        <div style="position:relative;padding:20px;color:#FAF6EF;width:100%">
          <div style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:17px">Announced soon</div>
          <div style="font-size:13px;opacity:.6">{s}</div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- AGENDA -->
<section id="agenda" data-reveal style="padding:clamp(64px,10vh,120px) clamp(20px,5vw,64px);background:#F1EADD">
  <div style="max-width:900px;margin:0 auto">
    <div style="font-size:12px;letter-spacing:.22em;color:#E4572E;font-weight:600;margin-bottom:14px">04 — AGENDA</div>
    <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(30px,3.8vw,50px);letter-spacing:-0.02em;margin:0 0 40px">The Day</h2>
    <div style="display:flex;flex-direction:column">
      {agenda.map((a) => (
        <div style="display:grid;grid-template-columns:110px 1fr;gap:20px;padding:24px 0;border-top:1.5px solid rgba(28,22,19,.15);align-items:baseline">
          <div style="font-family:'Space Grotesk',monospace;font-weight:600;font-size:14px;color:#E4572E">{a.time}</div>
          <div>
            <h3 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:22px;margin:0 0 6px">{a.title}</h3>
            <p style="font-size:15px;line-height:1.55;opacity:.7;margin:0">{a.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHO IT'S FOR -->
<section data-reveal style="padding:clamp(64px,10vh,120px) clamp(20px,5vw,64px);max-width:1100px;margin:0 auto;text-align:center">
  <div style="font-size:12px;letter-spacing:.22em;color:#E4572E;font-weight:600;margin-bottom:14px">05 — WHO IT'S FOR</div>
  <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(30px,3.8vw,50px);letter-spacing:-0.02em;margin:0 0 36px">If you're building a life here, this is for you.</h2>
  <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:12px">
    {audiences.map((aud) => (
      <span class="a-chip" style="border:1.5px solid #1C1613;border-radius:999px;padding:12px 24px;font-size:15px;font-weight:500">{aud}</span>
    ))}
  </div>
  <p style="font-size:16px;opacity:.65;margin:32px 0 0">Whatever stage you're at — someone in this room has been there, and got through it.</p>
</section>

<!-- PARTNER -->
<section id="partner" data-reveal style="padding:clamp(64px,10vh,120px) clamp(20px,5vw,64px);background:#1C1613;color:#FAF6EF">
  <div style="max-width:1200px;margin:0 auto">
    <div style="font-size:12px;letter-spacing:.22em;color:#E4572E;font-weight:600;margin-bottom:14px">06 — PARTNER WITH US</div>
    <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(30px,3.8vw,50px);letter-spacing:-0.02em;margin:0 0 16px;max-width:820px">Invest in the community everyone will want to have backed.</h2>
    <p style="max-width:680px;font-size:16px;line-height:1.65;opacity:.75;margin:0 0 44px">Finding X partners aren't sponsors of an event — they're early builders of an ecosystem helping African talent thrive in the UK, starting in Leeds.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:18px;align-items:stretch">
      {packages.map((p) => (
        <div style={`border:1.5px solid ${p.border};border-radius:20px;padding:32px 28px;display:flex;flex-direction:column;gap:16px;background:${p.bg}`}>
          <div style={`font-size:12px;letter-spacing:.18em;font-weight:600;color:${p.accent}`}>{p.tier}</div>
          <div style="font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:40px">{p.price}</div>
          <div style="font-size:15px;font-weight:600;opacity:.9">{p.tag}</div>
          <ul style="margin:0;padding:0 0 0 18px;display:flex;flex-direction:column;gap:8px;font-size:14px;line-height:1.5;opacity:.8">
            {p.benefits.map((b) => <li>{b}</li>)}
          </ul>
        </div>
      ))}
    </div>
    <a href="mailto:vo@builderscabal.com?subject=Finding%20X%20Partnership%20Enquiry" class="a-cta" style="display:inline-block;margin-top:36px;background:#E4572E;color:#FAF6EF;text-decoration:none;font-weight:600;font-size:16px;padding:16px 34px;border-radius:999px">Become a Partner →</a>
  </div>
</section>

<!-- ABOUT BC -->
<section data-reveal style="padding:clamp(64px,10vh,110px) clamp(20px,5vw,64px);max-width:900px;margin:0 auto;text-align:center">
  <img src="/assets/bc-logo.png" alt="BuildersCabal" style="height:40px;width:auto;margin-bottom:24px">
  <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(26px,3vw,40px);letter-spacing:-0.02em;margin:0 0 16px">Connect. Collaborate. Co-create.</h2>
  <p style="font-size:16px;line-height:1.7;opacity:.75;margin:0 0 24px">BuildersCabal gives Africa's builders the knowledge, networks, and opportunities to build and scale successful companies — across Nigeria, Ghana, Kenya, Rwanda, Uganda and the UK. Finding X is the first step abroad.</p>
  <a href="https://builderscabal.com" style="color:#E4572E;font-weight:600;text-decoration:none;font-size:15px">Visit builderscabal.com →</a>
</section>

<!-- VENUE -->
<section data-reveal style="padding:0 clamp(20px,5vw,64px) clamp(64px,10vh,110px);max-width:1200px;margin:0 auto">
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:0;border-radius:22px;overflow:hidden;border:1.5px solid rgba(28,22,19,.15)">
    <div style="padding:clamp(32px,5vw,56px);background:#FFFDF8;display:flex;flex-direction:column;justify-content:center;gap:12px">
      <div style="font-size:12px;letter-spacing:.22em;color:#E4572E;font-weight:600">07 — VENUE</div>
      <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:clamp(26px,3vw,40px);letter-spacing:-0.02em;margin:0">Find your way to us.</h2>
      <p style="font-size:15px;line-height:1.6;opacity:.75;margin:0">Finding X happens at <strong>[Venue Name]</strong>, Leeds.<br>Minutes from Leeds railway station.</p>
