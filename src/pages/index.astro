<script define:vars={{ EVENT_DATE_ISO }}>
  // ---- Countdown ----
  const target = new Date(EVENT_DATE_ISO).getTime();
  const pad = (n) => String(n).padStart(2, '0');
  const cd = {
    dd: document.querySelector('[data-cd="dd"]'),
    hh: document.querySelector('[data-cd="hh"]'),
    mm: document.querySelector('[data-cd="mm"]'),
    ss: document.querySelector('[data-cd="ss"]'),
  };
  const tick = () => {
    const diff = Math.max(0, target - Date.now());
    cd.dd.textContent = pad(Math.floor(diff / 86400000));
    cd.hh.textContent = pad(Math.floor(diff / 3600000) % 24);
    cd.mm.textContent = pad(Math.floor(diff / 60000) % 60);
    cd.ss.textContent = pad(Math.floor(diff / 1000) % 60);
  };
  tick();
  setInterval(tick, 1000);

  // ---- Mobile menu ----
  const burger = document.getElementById('fxnav-burger');
  const menu = document.getElementById('fx-menu');
  const setMenu = (open) => {
    menu.classList.toggle('open', open);
    burger.textContent = open ? '✕' : '☰';
  };
  burger.addEventListener('click', () => setMenu(!menu.classList.contains('open')));
  menu.querySelectorAll('[data-menu-link]').forEach((a) => a.addEventListener('click', () => setMenu(false)));
  window.matchMedia('(max-width: 840px)').addEventListener('change', () => setMenu(false));

  // ---- FAQ accordion (single open) ----
  const faqBtns = [...document.querySelectorAll('[data-faq-btn]')];
  faqBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling;
      const wasOpen = !answer.hidden;
      faqBtns.forEach((b) => {
        b.nextElementSibling.hidden = true;
        b.querySelector('[data-faq-icon]').textContent = '+';
      });
      if (!wasOpen) {
        answer.hidden = false;
        btn.querySelector('[data-faq-icon]').textContent = '−';
      }
    });
  });

  // ---- Newsletter ----
  const form = document.getElementById('fx-newsform');
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    document.getElementById('fx-subscribed').hidden = false;
  });

  // ---- GSAP motion ----
  const words = ['OPPORTUNITY', 'COMMUNITY', 'PURPOSE', 'CONFIDENCE', 'DIRECTION', 'HOME', 'PROSPERITY', 'X'];
  let wordIdx = 0;
  const waitGsap = (cb) => (window.gsap ? cb() : setTimeout(() => waitGsap(cb), 120));
  waitGsap(() => {
    const gsap = window.gsap;
    if (window.ScrollTrigger) gsap.registerPlugin(window.ScrollTrigger);
    // rotating hero word
    setInterval(() => {
      const el = document.getElementById('fx-rotword');
      if (!el) return;
      gsap.to(el, { y: -22, opacity: 0, duration: 0.26, ease: 'power2.in', onComplete: () => {
        wordIdx = (wordIdx + 1) % words.length;
        el.textContent = words[wordIdx];
        gsap.fromTo(el, { y: 26, opacity: 0 }, { y: 0, opacity: 1, duration: 0.34, ease: 'power3.out' });
      }});
    }, 2400);
    // scroll reveals
    if (window.ScrollTrigger) {
      gsap.utils.toArray('[data-reveal]').forEach((el) => {
        gsap.fromTo(el, { y: 46, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 88%' } });
      });
    }
    // hero intro
    const h1 = document.getElementById('fx-h1');
    if (h1) gsap.fromTo(h1.children, { y: 60, opacity: 0 }, { y: 0, opacity: 1, duration: 1, stagger: 0.12, ease: 'power4.out' });
  });
</script>
</body>
</html>
