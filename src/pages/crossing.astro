<script define:vars={{ EVENT_DATE_ISO }}>
  // ---- Countdown ----
  const target = new Date(EVENT_DATE_ISO).getTime();
  const pad = (n) => String(n).padStart(2, '0');
  const cd = {
    dd: document.querySelector('[data-cd="dd"]'),
    hh: document.querySelector('[data-cd="hh"]'),
    mm: document.querySelector('[data-cd="mm"]'),
    ss: document.querySelector('[data-cd="ss"]'),
  };
  const tick = () => {
    const diff = Math.max(0, target - Date.now());
    cd.dd.textContent = pad(Math.floor(diff / 86400000));
    cd.hh.textContent = pad(Math.floor(diff / 3600000) % 24);
    cd.mm.textContent = pad(Math.floor(diff / 60000) % 60);
    cd.ss.textContent = pad(Math.floor(diff / 1000) % 60);
  };
  tick();
  setInterval(tick, 1000);

  // ---- Mobile menu ----
  const burger = document.getElementById('xgnav-burger');
  const menu = document.getElementById('xg-menu');
  const setMenu = (open) => {
    menu.classList.toggle('open', open);
    burger.textContent = open ? '✕' : '☰';
  };
  burger.addEventListener('click', () => setMenu(!menu.classList.contains('open')));
  menu.querySelectorAll('[data-menu-link]').forEach((a) => a.addEventListener('click', () => setMenu(false)));
  window.matchMedia('(max-width: 840px)').addEventListener('change', () => setMenu(false));

  // ---- FAQ accordion (single open, lime bg when open) ----
  const faqBtns = [...document.querySelectorAll('[data-faq-btn]')];
  faqBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('[data-faq-item]');
      const answer = btn.nextElementSibling;
      const wasOpen = !answer.hidden;
      faqBtns.forEach((b) => {
        b.nextElementSibling.hidden = true;
        b.querySelector('[data-faq-icon]').textContent = '+';
        b.closest('[data-faq-item]').style.background = '#F4F2EC';
      });
      if (!wasOpen) {
        answer.hidden = false;
        btn.querySelector('[data-faq-icon]').textContent = '−';
        item.style.background = '#D8F34C';
      }
    });
  });

  // ---- Newsletter ----
  const form = document.getElementById('xg-newsform');
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    document.getElementById('xg-subscribed').hidden = false;
  });

  // ---- GSAP motion ----
  const words = ['OPPORTUNITY', 'COMMUNITY', 'PURPOSE', 'CONFIDENCE', 'DIRECTION', 'HOME', 'PROSPERITY', 'X'];
  let wordIdx = 0;
  const wait = (cb) => (window.gsap && window.ScrollTrigger) ? cb() : setTimeout(() => wait(cb), 120);
  wait(() => {
    const gsap = window.gsap;
    gsap.registerPlugin(window.ScrollTrigger);
    // hero stacked lines intro
    const h1 = document.getElementById('xg-h1');
    if (h1) gsap.fromTo(h1.children, { x: -60, opacity: 0 }, { x: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power4.out' });
    // rotating stamp word
    setInterval(() => {
      const el = document.getElementById('xg-rotword');
      if (!el) return;
      gsap.to(el, { scale: 0.6, opacity: 0, rotate: 6, duration: 0.22, ease: 'power2.in', onComplete: () => {
        wordIdx = (wordIdx + 1) % words.length;
        el.textContent = words[wordIdx];
        gsap.fromTo(el, { scale: 1.25, opacity: 0, rotate: -8 }, { scale: 1, opacity: 1, rotate: -2, duration: 0.34, ease: 'back.out(2.2)' });
      }});
    }, 2200);
    // ticker strip
    const ticker = document.getElementById('xg-ticker');
    if (ticker) {
      gsap.to(ticker, { xPercent: -33.34, ease: 'none', duration: 18, repeat: -1 });
    }
    // section reveals with hard clip wipe
    gsap.utils.toArray('[data-reveal]').forEach((el) => {
      gsap.fromTo(el, { clipPath: 'inset(0 0 100% 0)' }, { clipPath: 'inset(0 0 0% 0)', duration: 0.9, ease: 'power3.inOut',
        scrollTrigger: { trigger: el, start: 'top 85%' } });
    });
  });
</script>
